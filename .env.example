# ─────── TIME ───────
TZNAME=Asia/Singapore

# ─────── DEPLOY (deploy.sh only) ───────
# options: [k3s, cloud]
ENV_MODE=k3s

# ─────── DB ───────
# MYSQL_DATABASE=CHANGE_ME
# MYSQL_PASSWORD=CHANGE_ME
# DB_URL=CHANGE_ME

# ─────── AI ───────
# OPENAI_API_KEY=sk-CHANGE_ME
# GOOGLE_CLIENT_SECRETS_FILE=CHANGE_ME
# OAUTH_REDIRECT_URI=CHANGE_ME

# ─────── CLOUD ───────
# REGISTRY_URL=CHANGE_ME
# KUBECONFIG=CHANGE_ME

# ─────── WEAVIATE ───────
# default localhost，without open。
# Uncomment and fill in only if Weaviate runs on another host:
# WEAVIATE_HOST=localhost
# WEAVIATE_HTTP_PORT=8080
# WEAVIATE_GRPC_PORT=50051